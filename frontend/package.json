{
  "name": "imseller-studio-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:cov": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,css,json,md}\"",
    "gen:types": "openapi-typescript http://localhost:8001/openapi.json -o src/types/generated/api.d.ts",
    "gen:zod": "openapi-zod-client http://localhost:8001/openapi.json -o src/api/schemas-generated.ts --export-schemas && node scripts/strip-zodios-client.mjs src/api/schemas-generated.ts",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "check": "npm run typecheck && npm run lint && npm run test -- --run"
  },
  "size-limit": [
    {
      "name": "App JS (gzip)",
      "path": "dist/assets/index-*.js",
      "limit": "250 KB",
      "gzip": true
    },
    {
      "name": "App CSS (gzip)",
      "path": "dist/assets/index-*.css",
      "limit": "40 KB",
      "gzip": true
    }
  ],
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.100.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.11.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-error-boundary": "^4.1.2",
    "react-hook-form": "^7.74.0",
    "react-router-dom": "^7.14.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@size-limit/preset-app": "^11.2.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query-devtools": "^5.100.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "jsdom": "^25.0.0",
    "openapi-typescript": "^7.13.0",
    "openapi-zod-client": "^1.18.3",
    "prettier": "^3.8.3",
    "size-limit": "^11.2.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.1.7",
    "vitest": "^2.1.0"
  }
}
