# SoulX-FlashTalk environment template.
# Copy to `.env` and fill in actual values. `.env` is gitignored.

# ========================================
# External APIs
# ========================================
GEMINI_API_KEY=
ELEVENLABS_API_KEY=

# ========================================
# Server
# ========================================
HOST=0.0.0.0
PORT=8001
CORS_ORIGINS=http://localhost:5555,http://localhost:8001

# ========================================
# DB (PR0+)
# ========================================
MONGO_URL=mongodb://localhost:27017
DB_NAME=ai_showhost
STUDIO_JWT_SECRET=
STUDIO_JWT_TTL_DAYS=7

# ========================================
# AWS S3 (PR S3+) — required for media storage
# ========================================
# Bucket layout: <S3_BUCKET>/<S3_ENV_PREFIX>/<S3_PROJECT_NAME>/<storage_key>
S3_BUCKET=ailab-demo
S3_REGION=ap-northeast-2
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENV_PREFIX=dev
S3_PROJECT_NAME=imseller-studio

# Optional tuning (defaults are fine for PoC)
# S3_PRESIGN_TTL_IMAGE=3600
# S3_PRESIGN_TTL_VIDEO=21600
# S3_MAX_POOL_CONNECTIONS=50
